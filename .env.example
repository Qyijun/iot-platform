# 服务配置
NODE_ENV=production
PORT=3000
WS_PORT=3001

# 数据库配置 (支持 SQLite/MySQL/PostgreSQL)
# SQLite
DB_TYPE=sqlite
DB_PATH=./data/database.sqlite

# MySQL (取消注释并配置)
# DB_TYPE=mysql
# DB_HOST=192.168.1.3
# DB_PORT=3306
# DB_USER=your_user
# DB_PASSWORD=your_password
# DB_NAME=iot-platform

# PostgreSQL (取消注释并配置)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=iot-platform

# JWT密钥 (必须修改!)
JWT_SECRET=change-this-to-a-secure-random-string

# MQTT配置
MQTT_BROKER=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# 邮件服务 (可选)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@example.com

# CORS配置
CORS_ORIGIN=*

# 管理员默认账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
